:8080 {
	# API requests go to the Dart API server
	handle /api/* {
		reverse_proxy localhost:8081
	}

	# Everything else is the Flutter SPA
	handle {
		root * /opt/photisnadi/web
		try_files {path} /index.html
		file_server

		# Cache static assets
		@static path *.js *.css *.woff2 *.png *.svg *.ico
		header @static Cache-Control "public, max-age=31536000, immutable"
	}

	log {
		output stderr
		format json
	}
}
